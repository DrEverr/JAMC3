#!/usr/bin/env bash
# jam-build: Build a C3 JAM service into a .jam blob.
#
# Pipeline:
#   1. c3c compile-only  -> RISC-V .o files from C3 sources
#   2. clang -c          -> host_stubs.o (PolkaVM metadata for host imports)
#   3. jamtool           -> .jam blob (link + translate + serialize)
#
# Usage:
#   jam-build [options] <source.c3> [additional sources...]
#
# Options:
#   --output|-o <path>   Output file path (default: build/<name>.jam)
#   --release            Optimized build: -O2, no debug info, smaller output
#   --authorizer         Build as an authorizer instead of a service
#   --guest              Build as a CoreStation guest (.polkavm, not .jam)
#   --stack <bytes>      Stack size in bytes (default: 131072 = 128 KiB)
#   --sdk-dir <path>     Path to the JAM SDK directory (default: auto-detect)
#   --keep-intermediates Keep intermediate files next to output
#   --help|-h            Show this help message
#
# Build modes:
#   Default (debug):   -O0, -g (debug info for clear error messages)
#   --release:         -g0, no debug info. For --guest also enables -O2.
#                      Services always use -O0 (RISC-V optimization breaks PolkaVM register alignment).
#
# Requirements:
#   - c3c       (C3 compiler with elf-riscv64 target)
#   - clang     (for compiling host_stubs.c / guest_stubs.c)
#   - jamtool   (RISC-V .o -> .jam recompiler)
#   - polkatool (for --guest builds only)

set -euo pipefail

# ---- Defaults ----
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SDK_DIR="${SCRIPT_DIR}/../jamc3.c3l"

# In Docker the SDK lives at /opt/jamc3/jamc3.c3l.
if ! ls "${SDK_DIR}"/*.c3 &>/dev/null && [[ -d "/opt/jamc3/jamc3.c3l" ]]; then
    SDK_DIR="/opt/jamc3/jamc3.c3l"
fi

OUTPUT=""
RELEASE=false
AUTHORIZER=false
GUEST=false
KEEP_INTERMEDIATES=false
SOURCES=()
MIN_STACK_SIZE=131072  # 128 KiB
DEBUG_FLAG="-g"

# ---- Parse arguments ----
while [[ $# -gt 0 ]]; do
    case "$1" in
        --sdk-dir)
            SDK_DIR="$2"
            shift 2
            ;;
        --output|-o)
            OUTPUT="$2"
            shift 2
            ;;
        --release)
            RELEASE=true
            DEBUG_FLAG="-g0"
            shift
            ;;
        --authorizer)
            AUTHORIZER=true
            shift
            ;;
        --guest)
            GUEST=true
            shift
            ;;
        --stack)
            MIN_STACK_SIZE="$2"
            shift 2
            ;;
        --keep-intermediates)
            KEEP_INTERMEDIATES=true
            shift
            ;;
        --help|-h)
            sed -n '2,/^$/p' "$0" | sed 's/^# \?//'
            exit 0
            ;;
        -*)
            echo "Error: Unknown option: $1" >&2
            exit 1
            ;;
        *)
            SOURCES+=("$1")
            shift
            ;;
    esac
done

# Services always use -O0 (RISC-V -O1+ uses a6/a7 registers not in PolkaVM).
# Guests can use -O2 with --release since they run on full PolkaVM.
if [[ "$RELEASE" == true && "$GUEST" == true ]]; then
    OPT_LEVEL="O2"
else
    OPT_LEVEL="O0"
fi

if [[ ${#SOURCES[@]} -eq 0 ]]; then
    echo "Error: No source files specified." >&2
    echo "Usage: jam-build [options] <source.c3> [additional sources...]" >&2
    echo "       jam-build --help for all options" >&2
    exit 1
fi

# ---- Derive output name ----
FIRST_SOURCE="${SOURCES[0]}"
BASENAME="$(basename "${FIRST_SOURCE}" .c3)"

OUTPUT_EXT="jam"

if [[ -z "$OUTPUT" ]]; then
    OUTPUT="build/${BASENAME}.${OUTPUT_EXT}"
fi

mkdir -p "$(dirname "${OUTPUT}")"

# ---- Temp dir ----
TEMP_DIR=$(mktemp -d)
if [[ "$KEEP_INTERMEDIATES" == false ]]; then
    trap 'rm -rf "$TEMP_DIR"' EXIT
fi

OBJ_DIR="${TEMP_DIR}/obj"
mkdir -p "${OBJ_DIR}"

# ---- Check tools ----
if ! command -v c3c &>/dev/null; then
    echo "Error: c3c not found in PATH." >&2
    exit 1
fi

if ! command -v jamtool &>/dev/null; then
    echo "Error: jamtool not found in PATH. Install from https://github.com/DrEverr/jamtool" >&2
    exit 1
fi

# Find clang
CLANG=""
for v in 20 19 18 17 16 15 ""; do
    candidate="clang${v:+-$v}"
    if command -v "$candidate" &>/dev/null; then
        CLANG="$candidate"
        break
    fi
done
if [[ -z "$CLANG" ]]; then
    echo "Error: No clang compiler found." >&2
    exit 1
fi

# ---- Print build info ----
MODE="debug"
[[ "$RELEASE" == true ]] && MODE="release"
BUILD_TYPE="service"
[[ "$AUTHORIZER" == true ]] && BUILD_TYPE="authorizer"
[[ "$GUEST" == true ]] && BUILD_TYPE="guest"
echo "Building ${BUILD_TYPE} (${MODE}): ${SOURCES[*]} -> ${OUTPUT}"
echo ""

# ---- Collect SDK C3 sources ----
SDK_C3_SOURCES=()

if [[ "$GUEST" == true ]]; then
    # Guest builds: look for corestation runtime near source files
    GUEST_RT_DIR="$(dirname "${SOURCES[0]}")"
    for candidate in "${GUEST_RT_DIR}/corestation_rt.c3" "${GUEST_RT_DIR}/../corestation_rt.c3"; do
        if [[ -f "$candidate" ]]; then
            SDK_C3_SOURCES+=("$candidate")
            break
        fi
    done
else
    for f in "${SDK_DIR}"/*.c3; do
        [[ -f "$f" ]] || continue
        fname="$(basename "$f")"
        if [[ "$AUTHORIZER" == true && "$fname" == "entry.c3" ]]; then continue; fi
        if [[ "$AUTHORIZER" == false && "$fname" == "entry_authorizer.c3" ]]; then continue; fi
        SDK_C3_SOURCES+=("$f")
    done
fi

# ---- Step 1: Compile C3 -> RISC-V .o ----
echo "[1] Compiling C3 -> RISC-V objects..."

c3c compile-only \
    --target elf-riscv64 \
    --use-stdlib=no \
    --link-libc=no \
    --reloc=pic \
    --riscv-cpu=rvimac \
    --riscv-abi=int-only \
    ${DEBUG_FLAG} \
    -${OPT_LEVEL} \
    --obj-out "${OBJ_DIR}" \
    "${SDK_C3_SOURCES[@]}" \
    "${SOURCES[@]}"

C3_OBJS=()
for f in "${OBJ_DIR}"/*.o; do
    [[ -f "$f" ]] && C3_OBJS+=("$f")
done
echo "  -> ${#C3_OBJS[@]} object files"

# ---- Step 2: Compile stubs ----
if [[ "$GUEST" == true ]]; then
    GUEST_STUBS="$(dirname "${SOURCES[0]}")/guest_stubs.c"
    if [[ ! -f "$GUEST_STUBS" ]]; then
        GUEST_STUBS="$(dirname "${SOURCES[0]}")/../guest_stubs.c"
    fi
    if [[ ! -f "$GUEST_STUBS" ]]; then
        echo "Error: guest_stubs.c not found near source files." >&2
        exit 1
    fi

    echo "[2] Compiling guest stubs..."
    STUBS_OBJ="${OBJ_DIR}/guest_stubs.o"
    ${CLANG} \
        --target=riscv64-unknown-none-elf \
        -march=rv64imac_zbb -mabi=lp64 \
        -fpic -fPIE -mrelax \
        -nostdinc -nostdlib -fno-builtin \
        -c -o "${STUBS_OBJ}" "${GUEST_STUBS}"
else
    HOST_STUBS="${SDK_DIR}/host_stubs.c"
    if [[ ! -f "$HOST_STUBS" ]]; then
        echo "Error: host_stubs.c not found at ${HOST_STUBS}" >&2
        exit 1
    fi

    echo "[2] Compiling host stubs..."
    STUBS_OBJ="${OBJ_DIR}/host_stubs.o"
    STUBS_DEFINES=""
    [[ "$AUTHORIZER" == true ]] && STUBS_DEFINES="-DJAM_BUILD_AUTHORIZER=1"

    ${CLANG} \
        --target=riscv64-unknown-none-elf \
        -march=rv64imac_zbb -mabi=lp64 \
        -fpic -fPIE -mrelax \
        -nostdinc -nostdlib -fno-builtin \
        ${STUBS_DEFINES} \
        -c -o "${STUBS_OBJ}" "${HOST_STUBS}"
fi

echo "  -> ${STUBS_OBJ}"

# ---- Dispatch table ----
if [[ "$GUEST" == true ]]; then
    DISPATCH_TABLE="guest_main"
elif [[ "$AUTHORIZER" == true ]]; then
    DISPATCH_TABLE="jam_entry_is_authorized"
else
    DISPATCH_TABLE="jam_entry_refine,jam_entry_accumulate,jam_entry_accumulate,jam_entry_accumulate"
fi

# ---- Step 3: Build final output ----
echo "[3] jamtool -> .jam..."

JAMTOOL_FLAGS=""
[[ "$AUTHORIZER" == true ]] && JAMTOOL_FLAGS="--authorizer"

jamtool \
    --dispatch "${DISPATCH_TABLE}" \
    --min-stack-size ${MIN_STACK_SIZE} \
    ${JAMTOOL_FLAGS} \
    -o "${OUTPUT}" \
    "${C3_OBJS[@]}" "${STUBS_OBJ}"

echo ""
echo "Build complete: ${OUTPUT}"
SIZE=$(wc -c < "${OUTPUT}" | tr -d ' ')
echo "Size: ${SIZE} bytes"
